digraph StrictPositionedGlyphRunPlan {
  graph [rankdir=TB, bgcolor="white", fontname="Helvetica", label="Geordi strict positioned glyph-run 100-slice DAG", labelloc="t", fontsize=24];
  node [shape=box, style="rounded,filled", fillcolor="white", fontname="Helvetica", fontsize=10, margin="0.08,0.05"];
  edge [color="#64748b", arrowsize=0.6, penwidth=1.2];

  subgraph cluster_legend {
    label="Legend";
    color="#cbd5e1";
    legend_open [label="OPEN", color="#16a34a", penwidth=4];
    legend_blocked [label="BLOCKED", color="#dc2626", penwidth=4];
    legend_done [label="COMPLETED", color="#94a3b8", penwidth=3, style="rounded,filled,dashed", fontcolor="#64748b"];
  }

  subgraph cluster_law {
    label="Arc 1: Law";
    color="#e2e8f0";
