    S009 [label="S009\nGlyph evidence ladder and evidence kinds", color="#94a3b8", penwidth=3, style="rounded,filled,dashed", fontcolor="#64748b"];
    S010 [label="S010\nInitial fixture scope and nonclaims", color="#94a3b8", penwidth=3, style="rounded,filled,dashed", fontcolor="#64748b"];
    S011 [label="S011\nSlice DAG operating rule", color="#94a3b8", penwidth=3, style="rounded,filled,dashed", fontcolor="#64748b"];
    S012 [label="S012\nText compliance badge vocabulary", color="#94a3b8", penwidth=3, style="rounded,filled,dashed", fontcolor="#64748b"];
