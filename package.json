{
  "name": "geordi-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.30.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:exports": "pnpm build && node scripts/smoke-package-exports.mjs",
    "test:package-names": "node scripts/check-package-name-scope.mjs",
    "test:placeholders": "node scripts/check-test-placeholders.mjs",
    "test:repo-sludge": "node scripts/check-repo-sludge.mjs",
    "test:coverage": "turbo run test:coverage",
    "lint": "pnpm lint:root && turbo run lint",
    "lint:root": "eslint . --max-warnings 0",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "turbo": "^2.9.14",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  }
}
