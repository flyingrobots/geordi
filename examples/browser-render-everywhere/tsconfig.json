{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ES2022",
    "moduleResolution": "bundler",
    "paths": {
      "@flyingrobots/geordi-core": ["../../packages/core/src/index.ts"],
      "@flyingrobots/geordi-gpvue": ["../../packages/gpvue/src/index.ts"],
      "@flyingrobots/geordi-render-fixture": ["../../packages/render-fixture/src/index.ts"],
      "@flyingrobots/geordi-runtime-webgl": ["../../packages/runtime-webgl/src/index.ts"]
    },
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "allowUnusedLabels": false,
    "allowUnreachableCode": false,
    "skipLibCheck": true,
    "types": ["vite/client", "vitest/globals", "node"]
  },
  "include": ["src/**/*", "test/**/*", "playwright.config.ts", "vite.config.ts", "vitest.config.ts"]
}
