{
  "name": "@flyingrobots/geordi-example-browser-render-everywhere",
  "version": "0.1.0",
  "private": true,
  "description": "Browser canvas harness for the Geordi render-everywhere demo",
  "type": "module",
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc --noEmit && vite build",
